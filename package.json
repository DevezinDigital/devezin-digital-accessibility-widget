{
  "name": "@devezindigital/accessibility",
  "version": "1.0.0",
  "description": "Reusable, dependency-free accessibility widget, statement page, and a11y verification tooling (ESLint preset + axe harness + checklist) for multi-site Next.js deployment",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.esm.js",
      "require": "./dist/constants.js"
    },
    "./eslint": {
      "types": "./dist/eslint.d.ts",
      "import": "./dist/eslint.esm.js",
      "require": "./dist/eslint.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "import": "./dist/test.esm.js",
      "require": "./dist/test.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.esm.js",
      "require": "./dist/verify.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "github-action"
  ],
  "bin": {
    "accessibility-init": "./bin/index.js"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=19"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "eslint-plugin-jsx-a11y": "^6.0.0",
    "axe-core": "^4.0.0",
    "@testing-library/react": "^14.0.0 || ^15.0.0 || ^16.0.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-jsx-a11y": {
      "optional": true
    },
    "axe-core": {
      "optional": true
    },
    "@testing-library/react": {
      "optional": true
    }
  },
  "dependencies": {
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@testing-library/react": "^16.1.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "axe-core": "^4.10.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.6.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.34.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "ada",
    "react",
    "nextjs",
    "aria",
    "eslint",
    "axe"
  ],
  "author": "Devezin Digital",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevezinDigital/devezin-digital-accessibility-widget.git"
  }
}
